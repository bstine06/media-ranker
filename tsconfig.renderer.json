{
  "include": ["src/renderer/**/*"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "src/renderer/src",
    "outDir": "out/renderer",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}